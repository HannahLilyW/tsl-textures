{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2020", "dom"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "tsl-textures": ["./src/tsl-textures.d.ts"]
    }
  },
  "include": ["src/tsl-textures.d.ts", "src/tsl-textures-tests.ts"]
}
